<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Phase 1b forwards traffic: the firewall must re-originate every allowed connection
         through its own protect()ed sockets, which requires INTERNET. The app still makes no
         calls of its own — no servers, no analytics — so its own egress remains zero. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- A firewall must name every app that connects; resolves uids for ALL packages
         (Android 11+ package visibility). Justified use-case on Google Play for firewalls. -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />
    <!-- Boot-lock: re-arm the firewall (deny-all) on device boot. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Biometric app-lock unlock (BiometricPrompt). -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <application
        android:allowBackup="false"
        android:icon="@drawable/ic_shield"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.QOpsecFirewall">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".vpn.VpnFirewallService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:permission="android.permission.BIND_VPN_SERVICE">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="On-device firewall: inspects packets on a local VpnService tunnel so the user can allow or deny each connection. No data leaves the device." />
        </service>

        <!-- Kill-switch Quick Settings tile -->
        <service
            android:name=".vpn.KillSwitchTileService"
            android:exported="true"
            android:icon="@drawable/ic_shield"
            android:label="Kill switch"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- Boot-lock receiver -->
        <receiver
            android:name=".vpn.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
